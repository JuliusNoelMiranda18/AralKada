    {"id":45,"text":"(2,0) is midpoint of (-2,-2) and (x,y). (x,y)?","options":["(0,-2)","(6,2)","(-2,0)","(4,6)"],"answer":"B","explanation":"(x-2)/2=2 => x=6; (y-2)/2=0 => y=2.","hasDiagram":false},
