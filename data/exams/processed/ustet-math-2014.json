    {"id":6,"text":"Domain of f(x) = (2x+5)/(3x-4)","options":["x∈R","x≠4/3","x≠-5/2","x≠0"],"answer":"B","explanation":"3x-4≠0 => x≠4/3.","hasDiagram":false},
