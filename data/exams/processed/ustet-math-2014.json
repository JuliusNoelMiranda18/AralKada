    {"id":28,"text":"Comp. angles 2x+21 and 3x-26. Smaller angle?","options":["19","31","38","59"],"answer":"B","explanation":"5x-5=90, x=19. 2(19)+21=59, 3(19)-26=31. Smaller=31.","hasDiagram":false},
