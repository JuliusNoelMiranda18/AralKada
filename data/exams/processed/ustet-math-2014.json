    {"id":47,"text":"MC is 3 more than 5 times MD. CD=39. MC?","options":["6","18","33","42"],"answer":"C","explanation":"x + 5x+3 = 39 => 6x=36, x=6. MC=5(6)+3=33.","hasDiagram":false},
