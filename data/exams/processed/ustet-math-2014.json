    {"id":1,"text":"The product of two numbers is –108. Their sum is 3. Find the larger.","options":["9","12","15","18"],"answer":"B","explanation":"12 * -9 = -108, 12 + (-9) = 3. Larger is 12.","hasDiagram":false},
    {"id":2,"text":"The sum of two numbers is 13. One is 7 less than thrice the second. Find the larger.","options":["7","8","5","12"],"answer":"B","explanation":"x+y=13, x=3y-7 => 4y=20, y=5, x=8.","hasDiagram":false},
    {"id":3,"text":"Two numbers differ by 5. Larger is 2 less than twice the smaller. Find smaller.","options":["7","12","8","2"],"answer":"A","explanation":"x-y=5, x=2y-2 => y=7, x=12.","hasDiagram":false},
    {"id":4,"text":"Solve for x: √(2x+2) = 3-√x","options":["-49","-1","1","49"],"answer":"C","explanation":"√(2+2) = 3-1 => 2=2. x=1.","hasDiagram":false},
